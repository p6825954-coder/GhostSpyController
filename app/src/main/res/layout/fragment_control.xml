<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <Button android:id="@+id/btnFlash" android:text="Flashlight" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnLock" android:text="Lock" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnMute" android:text="Mute" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnVibrate" android:text="Vibrate" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnWallpaper" android:text="Wallpaper" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnCall" android:text="Call" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnToast" android:text="Toast" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnSpeak" android:text="Speak" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnOpenUrl" android:text="Open URL" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnWipe" android:text="Wipe Data" android:layout_margin="4dp"/>
    </LinearLayout>
</ScrollView>
